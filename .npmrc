# Choice Properties — npm configuration
#
# ignore-scripts=true prevents postinstall and prepare scripts from
# running automatically when Replit runs `npm install` on import.
# This stops any installed package from mutating the project or
# attempting to connect to external services at install time.
#
# This project has ZERO runtime npm dependencies.
# package.json contains no dependencies — only devDependencies for
# the local preview server (serve.js uses only Node.js built-ins).
#
# DO NOT add runtime dependencies to this project.
# DO NOT run npm install to add packages.
# DO NOT remove this file.
ignore-scripts=true
